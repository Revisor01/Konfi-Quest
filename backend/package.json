{
  "name": "konfi-points-backend",
  "version": "1.0.0",
  "description": "Backend API für das Konfi-Punkte-System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "docker compose -f docker-compose.test.yml up -d --wait && npx vitest run --config tests/vitest.config.ts; EXIT=$?; docker compose -f docker-compose.test.yml down; exit $EXIT",
    "test:ci": "npx vitest run --config tests/vitest.config.ts",
    "test:watch": "npx vitest --config tests/vitest.config.ts"
  },
  "keywords": [
    "konfi",
    "points",
    "church",
    "confirmation"
  ],
  "author": "Gemeinde Büsum & Wesselburen",
  "license": "CC BY-NC-SA 4.0",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "file-type": "^19.6.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "pg": "^8.16.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
